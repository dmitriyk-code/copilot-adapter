      "role": "user",
      "content": "[Tool Result (call_id: call_9ac55e0a584e)]\n1\tuse std::convert::Infallible;\n2\tuse std::sync::Arc;\n3\tuse std::time::Duration;\n4\t\n5\tuse axum::extract::State;\n6\tuse axum::response::sse::{Event, KeepAlive, Sse};\n7\tuse axum::response::{IntoResponse, Response};\n8\tuse axum::Json;\n9\tuse futures::StreamExt;\n10\t\n11\tuse crate::copilot::types::{\n12\t    ChatCompletionChunk, ChatCompletionRequest, ChunkChoice, ChunkDelta, MessageContent,\n13\t};\n14\tuse crate::error::AppError;\n15\tuse crate::server::AppState;\n16\tuse crate::tools::injector;\n17\tuse crate::tools::parser;\n18\t\n19\t/// Handler for `POST /v1/chat/completions`.\n20\t///\n21\t/// For non-streaming requests (`stream: false` or absent), forwards the request\n22\t/// to the Copilot API and returns the complete JSON response.\n23\t/// For streaming requests (`stream: true`), returns Server-Sent Events.\n24\t///\n25\t/// When the request contains tool definitions, they are injected into the system\n26\t/// prompt and tool calls are parsed from the model's text response.\n27\tpub async fn chat_completions(\n28\t    State(state): State<Arc<AppState>>,\n29\t    Json(request): Json<ChatCompletionRequest>,\n30\t) -> Result<Response, AppError> {\n31\t    tracing::debug!(\n32\t        model = %request.model,\n33\t        stream = ?request.stream,\n34\t        num_messages = request.messages.len(),\n35\t        \"Received chat completion request\"\n36\t    );\n37\t\n38\t    // TRACE: Log the full incoming request from Claude Code\n39\t    if tracing::enabled!(tracing::Level::TRACE) {\n40\t        if let Ok(json) = serde_json::to_string_pretty(&request) {\n41\t            tracing::trace!(\n42\t                direction = \"INCOMING\",\n43\t                source = \"Claude Code\",\n44\t                endpoint = \"/v1/chat/completions\",\n45\t                request_json = %json,\n46\t                \"Full request received from Claude Code\"\n47\t            );\n48\t        }\n49\t    }\n50\t\n51\t    // Validate: messages must be non-empty\n52\t    if request.messages.is_empty() {\n53\t        return Err(AppError::InvalidRequest(\n54\t            \"messages must be a non-empty array\".to_string(),\n55\t        ));\n56\t    }\n57\t\n58\t    let has_tools = request\n59\t        .tools\n60\t        .as_ref()\n61\t        .map_or(false, |t| !t.is_empty());\n62\t\n63\t    // Check if any messages have the \"tool\" role (indicating tool results).\n64\t    let has_tool_role = request.messages.iter().any(|m| m.role == \"tool\");\n65\t\n66\t    // Build the request to send upstream, applying tool injection if needed.\n67\t    let mut upstream_request = request.clone();\n68\t\n69\t    // Normalize the model name to match GitHub Copilot's expected format\n70\t    upstream_request.model = crate::model_mapper::normalize_model_name(&upstream_request.model);\n71\t\n72\t    if upstream_request.model != request.model {\n73\t        tracing::info!(\n74\t            original_model = %request.model,\n75\t            normalized_model = %upstream_request.model,\n76\t            \"Model name normalized for GitHub Copilot compatibility\"\n77\t        );\n78\t    }\n79\t\n80\t    // Inject tool definitions into the system prompt.\n81\t    // IMPORTANT: Only inject if tools are explicitly provided in this request.\n82\t    // Claude Code is responsible for re-sending tool definitions on every turn\n83\t    // when tool calling is active (including turns with tool-role messages).\n84\t    if let Some(ref tools) = request.tools {\n85\t        if !tools.is_empty() {\n86\t            tracing::debug!(\n87\t                num_tools = tools.len(),\n88\t                tool_names = ?tools.iter().map(|t| &t.function.name).collect::<Vec<_>>(),\n89\t                \"Injecting tools into prompt\"\n90\t            );\n91\t            injector::inject_tools_into_messages(&mut upstream_request.messages, tools);\n92\t        }\n93\t    } else if has_tool_role {\n94\t        // Tool-role messages are present but no tool definitions were provided.\n95\t        // This is likely a bug in the client (Claude Code should re-send tool\n96\t        // definitions on every turn). Log a warning to help debug.\n97\t        tracing::warn!(\n98\t            \"Request contains tool-role messages but no tool definitions. \\\n99\t             The model may generate malformed tool calls without schema context. \\\n100\t             Claude Code should re-send tool definitions on every turn when tool \\\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"
